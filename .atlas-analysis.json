  "keyFeatures": [
    "TSX/JSX compilation to Luau with react-lua",
    "Full TypeScript type preservation in output",
    "HTML element mapping to Roblox GUI classes",
    "Zero runtime dependencies",
    "Built-in CSS support via rbx-css",
    "Watch mode and project scaffolding",
    "Rojo project integration"
  ],
  "publicApiSurface": [
    "rbx-tsx compile <input> [-o <output>] [--css] [--react-path <path>] [--strict] [--sourcemap]",
    "rbx-tsx watch <path> [-o <output>] [--react-path <path>]",
    "rbx-tsx check <input> [--strict]",
    "rbx-tsx init [directory] [-n <name>]"
  ]
